---
import AppLayout from '@/layout/AppLayout.astro';
import MainLayout from '@/layout/MainLayout.astro';
import {AuthCard} from '@/components/AuthCard';


const { type } = Astro.params;


if (!type || !["login", "register"].includes(type)) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

const capitalisedType = type.charAt(0).toUpperCase() + type.slice(1);
const pageTitle = `${capitalisedType} | RealEstate by Alfath Muqoddas`;

---
<AppLayout>
    <title slot="head">{pageTitle}</title>
    <meta slot="head" name="og:title" content={pageTitle} />
    <meta slot="head" name="description" content={pageTitle} />
    <MainLayout>
    <section class="flex items-center justify-center min-h-[calc(100vh-12rem)]">
        <div class="w-full max-w-sm">
        <AuthCard type={type} client:load/>
        </div>
    </section>
    </MainLayout>
</AppLayout>