---
import AppLayout from "@/layout/AppLayout.astro";
import MainLayout from "@/layout/MainLayout.astro";
import CardCarousel from "@/components/EmblaCardCarousel";
import {ListingSidebar} from "@/components/listingSidebar";
import { Bed, Bath } from "lucide-react";
import Pagination from "@/components/pagination"
import { PUBLIC_API_URL } from "astro:env/client";
import { FavoritesToggle } from "@/components/FavoritesToggle";
import { parsePropertyQuery } from "@/lib/query/listings";
import { fetchListings } from "@/lib/api/listings";
import { buildListingMeta } from "@/lib/utils/listingsMeta";

const token = Astro.cookies.get("session")?.value;

const query = parsePropertyQuery(Astro.request);
if (!query) return Astro.redirect("/404");
const url = new URL(Astro.request.url);


const { data: listings, error: fetchError } = await fetchListings({
  apiUrl: PUBLIC_API_URL,
  searchParams: url.searchParams,
  token,
});

const {
  isApartemen,
  isRent,
  pageTitle,
  startIndex,
  endIndex,
} = buildListingMeta({
  listings,
  query,
  fetchError,
});

---
<AppLayout>
    <title slot="head">{pageTitle}</title>
    <meta slot="head" name="og:title" content={pageTitle} />
    <meta slot="head" name="description" content={pageTitle} />
    <!-- opengraph meta -->
     <meta slot="head" property="og:type" content="website" />
    <meta slot="head" property="og:url" content={Astro.url} />
    <meta slot="head" property="og:title" content={pageTitle} />
    <meta slot="head" property="og:description" content={pageTitle} />

    <!-- twitter meta -->
    <meta slot="head" property="twitter:card" content="summary_large_image" />
    <meta slot="head" property="twitter:url" content={Astro.url} />
    <meta slot="head" property="twitter:title" content={pageTitle} />
    <meta slot="head" property="twitter:description" content={pageTitle} />

    <MainLayout>
    <div class="flex gap-6">
        <div class="hidden md:block basis-1/5 grow-0 shrink-0">
            <ListingSidebar client:load initialQuery={query} />
        </div>
    
        {fetchError || !listings ? 
        <div class="flex-1 flex flex-col items-center justify-center p-10 bg-gray-50 rounded-2xl">
                <p class="text-red-500 font-bold">Oops! We couldn't load the properties. {PUBLIC_API_URL} is down or your internet connection is slow.</p>
                <button onclick="window.location.reload()" class="mt-4 text-blue-500 underline">Try again</button>
        </div>
         : 
        <div class="md:basis-4/5 grow-0 min-w-0">
            <h1 class="text-2xl font-bold text-primary">{listings.pagination.total} {isApartemen ? "Apartemen" : "Rumah"} {isRent ? "Disewa" : "Dijual"} {query.province ? `di ${query.province}` : ""}{query.city ? `, ${query.city}` : ""}</h1>
            <p class="text-sm text-muted-foreground">Showing {startIndex} - {endIndex} property</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                {listings.data.length === 0 ? (<div class="mt-10 text-center">No properties found matching your criteria.</div>
                ) : (
                listings.data.map((item) => (
                        <a href={`/listings/${item.id}`} class="group bg-white rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300 flex flex-col overflow-hidden relative">
                             <div class="absolute top-2 right-2 z-10">
                                    <FavoritesToggle client:visible initialFavorite={!!item.favorites?.length} token={token ?? ""} propertyId={item.id ?? ""}/>
                            </div>
                            
                            <CardCarousel client:load images={item.images} />
                            
                            <div class="flex flex-col p-4 ">
                                <h1 class="text-xl font-bold text-primary">Rp {item.propertyPrice?.toLocaleString("id-ID")}</h1>
                                <p class="truncate">{item.propertyTitle}</p>
                                <p class="text-sm text-muted-foreground border-b border-gray-200 pb-4 pt-1">{item.propertyAddressProvince}, {item.propertyAddressCity}</p>
                            
                                <div class="flex pt-4 gap-4 font-heading text-sm">
                                    <div class="flex gap-1 items-center">
                                        <Bed className="w-4 h-4" />
                                        <span class="font-bold">{item.propertyKamarTidur}</span>
                                    </div>
                                    <div class="flex gap-1 items-center">
                                        <Bath className="w-4 h-4" />
                                        <span class="font-bold">{item.propertyKamarMandi}</span>
                                    </div>
                                    <div class="flex gap-1 items-center">
                                        <p>LB</p>
                                        <span class="font-bold">{item.propertyLuasBangunan} m<sup>2</sup></span>
                                    </div>
                                     <div class="flex gap-1 items-center">
                                        <p>LT</p>
                                        <span class="font-bold">{item.propertyLuasTanah} m<sup>2</sup></span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    ))
                )}
            </div>
            <Pagination client:visible currentPage={listings.pagination.page} totalPages={listings.pagination.totalPages} />
        </div>}
    </div>
</MainLayout>
</AppLayout>